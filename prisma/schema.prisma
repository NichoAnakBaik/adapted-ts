generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                  @id @default(uuid())
  nama_lengkap           String
  username               String                  @unique
  password               String
  role                   Role                    @default(SISWA)
  created_at             DateTime                @default(now())
  updated_at             DateTime                @updatedAt
  attendances            Attendance[]
  sertifikat_siswa       Certificate[]           @relation("SertifikatSiswa")
  kelas_diajar           Class[]                 @relation("PengajarKelas")
  enrollments            Enrollment[]
  exam_assignments       ExamAssignment[]
  exam_attempts          ExamAttempt[]
  forum_messages         ForumMessage[]
  learning_progresses    LearningProgress[]
  notifications          Notification[]
  recommendation_history RecommendationHistory[]
  student_activity_logs  StudentActivityLog[]
}

model Notification {
  id         String   @id @default(uuid())
  user_id    String
  title      String
  message    String
  link       String?
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Class {
  id                  String              @id @default(uuid())
  name                String
  type                ClassType           @default(ONLINE)
  schedule            String?
  teacher_id          String?
  created_at          DateTime            @default(now())
  updated_at          DateTime            @updatedAt
  meeting_link        String?
  level               Int                 @default(1)
  module_link         String?
  attendance_sessions AttendanceSession[]
  certificates        Certificate[]
  teacher             User?               @relation("PengajarKelas", fields: [teacher_id], references: [id])
  enrollments         Enrollment[]
  exams               Exam[]
  forums              Forum[]
  learning_progresses LearningProgress[]
}

model Enrollment {
  id         String   @id @default(uuid())
  student_id String
  class_id   String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  status     String   @default("APPROVED")
  class      Class    @relation(fields: [class_id], references: [id], onDelete: Cascade)
  student    User     @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@unique([student_id, class_id])
}

model Exam {
  id               String           @id @default(uuid())
  class_id         String
  title            String
  description      String?
  time_limit       Int?
  is_published     Boolean          @default(false)
  is_final         Boolean          @default(false)
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt
  class            Class            @relation(fields: [class_id], references: [id], onDelete: Cascade)
  exam_assignments ExamAssignment[]
  exam_attempts    ExamAttempt[]
  questions        Question[]
}

model Question {
  id                String            @id @default(uuid())
  exam_id           String
  type              QuestionType
  question_text     String
  answer_key        String?
  audio_reference   String?
  difficulty        Int?              @default(1)
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt
  format            String            @default("ESSAY")
  option_a          String?
  option_b          String?
  option_c          String?
  option_d          String?
  image_url         String?
  exam              Exam              @relation(fields: [exam_id], references: [id], onDelete: Cascade)
  question_attempts QuestionAttempt[]
}

model Certificate {
  id           String            @id @default(uuid())
  student_id   String
  class_id     String
  file_url     String?
  status       CertificateStatus @default(PENDING)
  created_at   DateTime          @default(now())
  updated_at   DateTime          @updatedAt
  available_at DateTime?
  class        Class             @relation(fields: [class_id], references: [id], onDelete: Cascade)
  student      User              @relation("SertifikatSiswa", fields: [student_id], references: [id], onDelete: Cascade)
}

model Forum {
  id         String         @id @default(uuid())
  class_id   String
  title      String?
  created_at DateTime       @default(now())
  updated_at DateTime       @updatedAt
  class      Class          @relation(fields: [class_id], references: [id], onDelete: Cascade)
  messages   ForumMessage[]
}

model ForumMessage {
  id         String         @id @default(uuid())
  forum_id   String
  user_id    String
  message    String
  created_at DateTime       @default(now())
  updated_at DateTime       @updatedAt
  parent_id  String?
  reactions  String?
  forum      Forum          @relation(fields: [forum_id], references: [id], onDelete: Cascade)
  parent     ForumMessage?  @relation("ForumThread", fields: [parent_id], references: [id], onDelete: Cascade)
  replies    ForumMessage[] @relation("ForumThread")
  user       User           @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model StudentActivityLog {
  id          String       @id @default(uuid())
  student_id  String
  action_type ActivityType
  duration    Int?         @default(0)
  metadata    String?
  created_at  DateTime     @default(now())
  student     User         @relation(fields: [student_id], references: [id], onDelete: Cascade)
}

model ExamAttempt {
  id                String            @id @default(uuid())
  exam_id           String
  student_id        String
  start_time        DateTime          @default(now())
  end_time          DateTime?
  total_score       Int?              @default(0)
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt
  exam              Exam              @relation(fields: [exam_id], references: [id], onDelete: Cascade)
  student           User              @relation(fields: [student_id], references: [id], onDelete: Cascade)
  question_attempts QuestionAttempt[]
}

model QuestionAttempt {
  id                 String      @id @default(uuid())
  exam_attempt_id    String
  question_id        String
  student_answer     String?
  audio_url          String?
  transcript         String?
  time_spent_seconds Int?        @default(0)
  score              Int?        @default(0)
  ai_feedback        String?
  created_at         DateTime    @default(now())
  updated_at         DateTime    @updatedAt
  exam_attempt       ExamAttempt @relation(fields: [exam_attempt_id], references: [id], onDelete: Cascade)
  question           Question    @relation(fields: [question_id], references: [id], onDelete: Cascade)
}

model ExamAssignment {
  id          String   @id @default(uuid())
  exam_id     String
  student_id  String
  assigned_by String?
  created_at  DateTime @default(now())
  exam        Exam     @relation(fields: [exam_id], references: [id], onDelete: Cascade)
  student     User     @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@unique([exam_id, student_id])
}

model LearningProgress {
  id            String    @id @default(uuid())
  student_id    String
  is_completed  Boolean   @default(false)
  last_accessed DateTime? @default(now())
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  class_id      String
  class         Class     @relation(fields: [class_id], references: [id], onDelete: Cascade)
  student       User      @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@unique([student_id, class_id])
}

model RecommendationHistory {
  id                  String   @id @default(uuid())
  student_id          String
  recommendation_text String
  recommendation_type String
  is_applied          Boolean  @default(false)
  created_at          DateTime @default(now())
  student             User     @relation(fields: [student_id], references: [id], onDelete: Cascade)
}

model AttendanceSession {
  id          String       @id @default(uuid())
  class_id    String
  title       String
  description String?
  date        DateTime?
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt
  attendances Attendance[]
  class       Class        @relation(fields: [class_id], references: [id], onDelete: Cascade)
}

model Attendance {
  id            String            @id @default(uuid())
  student_id    String
  session_id    String
  status        AttendanceStatus  @default(PRESENT)
  check_in_time DateTime?
  notes         String?
  created_at    DateTime          @default(now())
  updated_at    DateTime          @updatedAt
  session       AttendanceSession @relation(fields: [session_id], references: [id], onDelete: Cascade)
  student       User              @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@unique([student_id, session_id])
}

enum Role {
  ADMIN
  PENGAJAR
  SISWA
}

enum ClassType {
  ONLINE
  OFFLINE
}

enum QuestionType {
  SPEAKING
  LISTENING
  WRITING
  READING
  MULTIPLE_CHOICE
}

enum CertificateStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  EXCUSED
  LATE
}

enum ActivityType {
  LOGIN
  LOGOUT
  MODULE_ACCESS
  QUIZ_ATTEMPT
  EXAM_ATTEMPT
  FORUM_PARTICIPATION
}
